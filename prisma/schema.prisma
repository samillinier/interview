// Prisma Schema for Installer Prescreening System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Installer model - stores all installer information
model Installer {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // Basic Information
  firstName             String
  lastName              String
  email                 String    @unique
  phone                 String?
  digitalId             String?   // Optional internal/digital identifier
  workroom              String?   // Workroom (office/branch) location label
  
  // Work Experience
  yearsOfExperience     Int?
  flooringSpecialties   String?   // JSON array stored as string
  previousEmployers     String?
  
  // Crew & Equipment
  hasOwnCrew            Boolean   @default(false)
  crewSize              Int?
  hasOwnTools           Boolean   @default(false)
  hasVehicle            Boolean   @default(false)
  toolsDescription      String?
  
  // Service Areas
  serviceAreas          String?   // JSON array of cities/regions
  willingToTravel       Boolean   @default(false)
  maxTravelDistance     Int?      // in miles
  
  // Availability
  availability          String?   // full-time, part-time, contract
  canStartImmediately   Boolean   @default(false)
  preferredStartDate    DateTime?
  
  // Licensing & Insurance
  hasInsurance          Boolean   @default(false)
  insuranceType         String?
  hasLicense            Boolean   @default(false)
  licenseNumber         String?
  licenseExpiry         DateTime?
  hasGeneralLiability         Boolean   @default(false)
  hasCommercialAutoLiability  Boolean   @default(false)
  hasWorkersComp              Boolean   @default(false)
  hasWorkersCompExemption     Boolean   @default(false)
  isSunbizRegistered          Boolean   @default(false)
  isSunbizActive              Boolean   @default(false)
  hasBusinessLicense          Boolean   @default(false)
  feiEin                     String?   // FEI / EIN (Federal Employer Identification Number)
  employerLiabilityPolicyNumber String? // Employer Liability Policy Number
  
  // Insurance & Certificate Expiry Dates
  llrpExpiry                 DateTime? // LLRP expiry date
  btrExpiry                  DateTime? // BTR expiry date
  workersCompExemExpiry      DateTime? // Workers Compensation Exemption Certificate expiry date
  workersCompExemExpiryDates String?   // JSON array of workers comp certificate expiry dates (YYYY-MM-DD)
  generalLiabilityExpiry     DateTime? // General Liability expiry date
  automobileLiabilityExpiry   DateTime? // Automobile Liability expiry date
  automobileLiabilityExpiryDates String? // JSON array of automobile liability policy expiry dates (YYYY-MM-DD)
  employersLiabilityExpiry   DateTime? // Employer's Liability expiry date
  
  // Background Check
  canPassBackgroundCheck      Boolean?
  backgroundCheckDetails      String?
  
  // Vehicle
  vehicleDescription          String?
  
  // Skills
  flooringSkills              String?   // JSON array of skills
  
  // Schedule Availability
  mondayToFridayAvailability  String?
  saturdayAvailability        String?
  
  // Travel
  openToTravel                Boolean   @default(false)
  travelLocations             String?   // JSON array of locations
  
  // Prescreening Results
  status                String    @default("pending") // pending, passed, failed, review, active
  passFailReason        String?
  overallScore          Int?      // 0-100
  
  // Notes & Follow-up
  notes                 String?
  followUpDate          DateTime?
  followUpReason        String?

  // Account Information
  username                    String?   @unique
  passwordHash                String?
  emailVerificationToken      String?
  emailVerifiedAt             DateTime?
  passwordResetToken          String?
  photoUrl                    String?
  
  // Company Information
  companyName                 String?
  companyTitle                String?
  companyStreetAddress        String?
  companyCity                 String?
  companyState                String?
  companyZipCode              String?
  companyCounty               String?
  companyAddress              String?   // Full formatted address
  ndaAgreedAt                 DateTime?
  
  // Service Agreement
  serviceAgreementSignedAt    DateTime?
  serviceAgreementSignature   String?
  serviceAgreementName        String?
  serviceAgreementDate        DateTime?
  
  // Carpet Installation
  wantsToAddCarpet            Boolean?
  installsStretchInCarpet     Boolean?
  dailyStretchInCarpetSqft    Int?
  installsGlueDownCarpet      Boolean?
  
  // Hardwood Installation
  wantsToAddHardwood          Boolean?
  installsNailDownSolidHardwood Boolean?
  dailyNailDownSolidHardwoodSqft Int?
  installsStapleDownEngineeredHardwood Boolean?
  
  // Laminate Installation
  wantsToAddLaminate          Boolean?
  dailyLaminateSqft           Int?
  installsLaminateOnStairs    Boolean?
  
  // Vinyl Installation
  wantsToAddVinyl             Boolean?
  installsSheetVinyl          Boolean?
  installsLuxuryVinylPlank    Boolean?
  dailyLuxuryVinylPlankSqft   Int?
  installsLuxuryVinylTile     Boolean?
  installsVinylCompositionTile Boolean?
  dailyVinylCompositionTileSqft Int?
  
  // Tile Installation
  wantsToAddTile              Boolean?
  installsCeramicTile         Boolean?
  dailyCeramicTileSqft        Int?
  installsPorcelainTile      Boolean?
  dailyPorcelainTileSqft     Int?
  installsStoneTile           Boolean?
  dailyStoneTileSqft          Int?
  offersTileRemoval           Boolean?
  installsTileBacksplash      Boolean?
  dailyTileBacksplashSqft     Int?
  
  // Additional Work
  movesFurniture              Boolean?
  installsTrim                Boolean?
  
  // Payment Information
  paymentCompanyName          String?
  paymentContactPerson        String?
  paymentPhoneNumber          String?
  paymentBusinessAddress      String?
  paymentEmailAddress         String?
  paymentBankName             String?
  paymentAccountName          String?
  paymentAccountNumber         String?
  paymentRoutingNumber        String?
  paymentAccountType          String?
  paymentAuthorizationName    String?
  paymentAuthorizationSignature String?
  paymentAuthorizationDate    DateTime?

  
  // Relationships
  interviews            Interview[]
  documents             Document[]
  communications        Communication[]
  notifications         Notification[]
  jobApplications       JobApplication[]
  staffMembers          StaffMember[]
  history               InstallerHistory[]
}

// Interview model - stores each prescreening interview
model Interview {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  installerId     String
  installer       Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  
  status          String    @default("in_progress") // in_progress, completed, abandoned
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  
  // Interview data
  transcript      String?   // Full conversation transcript
  extractedData   String?   // JSON of extracted information
  aiAnalysis      String?   // AI's analysis and recommendations
  
  // Questions and Answers
  responses       InterviewResponse[]
}

// Individual question responses
model InterviewResponse {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  
  interviewId     String
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  
  questionId      String
  questionText    String
  answerText      String?
  answerAudio     String?   // Path to audio file if voice response
  
  // AI extraction
  extractedValue  String?
  confidence      Float?    // 0-1 confidence score
}

// Documents uploaded by installers
model Document {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now())
  
  installerId           String
  installer             Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  
  type                  String    // insurance, license, certification, other
  name                  String
  url                   String
  verified              Boolean   @default(false)
  verifiedAt            DateTime?
  expiryDate            DateTime?
  verificationLink      String?
  verificationLinkStatus String?  // active, expired, pending
}

// Communications log
model Communication {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  
  installerId     String
  installer       Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  
  type            String    // email, sms, notification
  subject         String?
  content         String
  status          String    @default("sent") // sent, delivered, failed
  sentAt          DateTime  @default(now())
}

// Prescreening criteria configuration
model ScreeningCriteria {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  name            String
  description     String?
  isActive        Boolean   @default(true)
  
  // Criteria rules (JSON)
  rules           String    // JSON array of rules
  
  // Weights for scoring
  weights         String?   // JSON object of field weights
}


// Notifications for installers
model Notification {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  installerId     String
  installer       Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  
  type            String    // notification, message, news, job
  title           String
  content         String
  priority        String    @default("normal") // low, normal, high, urgent
  link            String?
  isRead          Boolean   @default(false)
  readAt          DateTime?
  
  // Sender information
  senderId        String?
  senderType      String?   // admin, installer
  
  @@index([installerId])
  @@index([type])
  @@index([isRead])
}

// Jobs posted by admin
model Job {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  title           String
  description     String
  location        String
  jobType         String    // full-time, part-time, contract, project
  requirements    String?   // JSON array of requirements
  skills          String?   // JSON array of required skills
  payRange        String?   // e.g., "$50-75/hour" or "$5000-8000/project"
  startDate       DateTime?
  endDate         DateTime?
  status          String    @default("active") // active, closed, filled
  
  // Who can see this job
  targetStatus    String?   // passed, qualified, all - who can apply
  
  // Benefits (JSON array of selected benefits)
  benefits        String?   // JSON array of benefits
  
  applications    JobApplication[]
  
  @@index([status])
  @@index([createdAt])
}

// Job applications from installers
model JobApplication {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  
  jobId           String
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  installerId     String
  installer       Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  
  status          String    @default("pending") // pending, reviewed, accepted, rejected
  notes           String?
  
  @@unique([jobId, installerId])
  @@index([installerId])
  @@index([jobId])
  @@index([status])
}

// Staff/Crew members working for an installer
model StaffMember {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  installerId     String
  installer       Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  
  // Basic Information
  firstName       String
  lastName        String
  digitalId       String?   // Optional internal/digital identifier
  email           String?
  phone           String?
  location        String?   // City, State or full address
  photoUrl        String?
  
  // Additional Information
  title           String?   // Job title/role
  yearsOfExperience Int?
  notes           String?
  
  @@index([installerId])
}

// Historical Installer Data - stores past years' data
model InstallerHistory {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  installerId           String
  installer             Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  year                  Int       // Year this data is for (e.g., 2024, 2025)
  
  // Basic Information
  firstName             String?
  lastName              String?
  phone                 String?
  digitalId             String?
  workroom              String?
  
  // Work Experience
  yearsOfExperience     Int?
  flooringSpecialties   String?
  flooringSkills        String?
  previousEmployers     String?
  
  // Crew & Equipment
  hasOwnCrew            Boolean?
  crewSize              Int?
  hasOwnTools           Boolean?
  hasVehicle            Boolean?
  toolsDescription      String?
  vehicleDescription    String?
  
  // Service Areas
  serviceAreas          String?
  willingToTravel       Boolean?
  maxTravelDistance     Int?
  
  // Availability
  availability          String?
  canStartImmediately   Boolean?
  preferredStartDate    DateTime?
  mondayToFridayAvailability String?
  saturdayAvailability  String?
  
  // Licensing & Insurance
  hasInsurance          Boolean?
  insuranceType         String?
  hasLicense            Boolean?
  licenseNumber         String?
  licenseExpiry         DateTime?
  hasGeneralLiability   Boolean?
  hasCommercialAutoLiability Boolean?
  hasWorkersComp        Boolean?
  hasWorkersCompExemption Boolean?
  isSunbizRegistered   Boolean?
  isSunbizActive        Boolean?
  hasBusinessLicense    Boolean?
  
  // Background Check
  canPassBackgroundCheck Boolean?
  backgroundCheckDetails String?

  // Insurance & Certificate Expiry Dates (multi-policy support)
  workersCompExemExpiryDates String?
  automobileLiabilityExpiryDates String?
  
  // Company Information
  companyName           String?
  companyTitle          String?
  companyStreetAddress  String?
  companyCity           String?
  companyState          String?
  companyZipCode        String?
  companyCounty         String?
  companyAddress        String?
  
  // Carpet Installation
  wantsToAddCarpet      Boolean?
  installsStretchInCarpet Boolean?
  dailyStretchInCarpetSqft Int?
  installsGlueDownCarpet Boolean?
  
  // Hardwood Installation
  wantsToAddHardwood    Boolean?
  installsNailDownSolidHardwood Boolean?
  dailyNailDownSolidHardwoodSqft Int?
  installsStapleDownEngineeredHardwood Boolean?
  
  // Laminate Installation
  wantsToAddLaminate    Boolean?
  dailyLaminateSqft     Int?
  installsLaminateOnStairs Boolean?
  
  // Vinyl Installation
  wantsToAddVinyl       Boolean?
  installsSheetVinyl    Boolean?
  installsLuxuryVinylPlank Boolean?
  dailyLuxuryVinylPlankSqft Int?
  installsLuxuryVinylTile Boolean?
  installsVinylCompositionTile Boolean?
  dailyVinylCompositionTileSqft Int?
  
  // Tile Installation
  wantsToAddTile        Boolean?
  installsCeramicTile   Boolean?
  dailyCeramicTileSqft  Int?
  installsPorcelainTile Boolean?
  dailyPorcelainTileSqft Int?
  installsStoneTile     Boolean?
  dailyStoneTileSqft    Int?
  offersTileRemoval     Boolean?
  installsTileBacksplash Boolean?
  dailyTileBacksplashSqft Int?
  
  // Additional Work
  movesFurniture        Boolean?
  installsTrim          Boolean?
  
  // Notes
  notes                 String?
  
  @@unique([installerId, year])
  @@index([installerId])
  @@index([year])
}

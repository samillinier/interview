# OpenAI API Key - Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Database URL
# This project uses PostgreSQL (see `prisma/schema.prisma`).
# Local: use any Postgres connection string (Neon, Docker, etc.)
# Vercel Postgres (Production):
#   - Vercel automatically creates Postgres env vars in your project
#   - Set DATABASE_URL to the pooled connection string
#   - Set DATABASE_URL_UNPOOLED to the non-pooled/direct connection string (used for Prisma migrations via `directUrl`)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
#
# --- If the app says the DB is not connected ---
# - Next.js loads `.env` first, then `.env.local`. Any `DATABASE_URL` in `.env.local` overrides `.env`; remove or fix stale values.
# - Remote Postgres (Neon, etc.): include `?sslmode=require` on the URL.
# - Neon: free projects suspend when idle — open https://console.neon.tech and your branch, then retry.
# - After editing env files, stop and restart `npm run dev` (Prisma reads env at process start).
# - Quick check (dev only): open http://localhost:3000/api/health/db — JSON explains Prisma errors (P1001, P1000, etc.).
# - CLI: `npx prisma migrate status` should succeed when the connection string is valid.

# Base URL for the application
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth Configuration
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl

# Adobe Sign — Independent Contractor Services Agreement web form (public eSign widget URL)
# Use the full widget URL (including the trailing `*` if present).
ADOBE_SIGN_CONTRACT_ESIGN_WIDGET_URL="https://na2.documents.adobe.com/public/esignWidget?wid=CBFCIBAA3AAABLblqZhDs4AEhql4PJpxJSBr3jAUYbOPkCUDhFvx9stwDoWbP6-TE_Cn8JqgWp0ME6NGCegg*"
NEXT_PUBLIC_ADOBE_SIGN_CONTRACT_ESIGN_WIDGET_URL="https://na2.documents.adobe.com/public/esignWidget?wid=CBFCIBAA3AAABLblqZhDs4AEhql4PJpxJSBr3jAUYbOPkCUDhFvx9stwDoWbP6-TE_Cn8JqgWp0ME6NGCegg*"

# Microsoft Azure AD Configuration
# Create an app at https://portal.azure.com -> Azure Active Directory -> App registrations
AZURE_AD_CLIENT_ID=your-azure-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret
AZURE_AD_TENANT_ID=your-azure-tenant-id

# Google Maps API Key (Optional but recommended for production)
# Get yours at https://console.cloud.google.com/google/maps-apis
# Enable "Maps Embed API" in your Google Cloud project
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Resend Email Configuration
# Get your API key at https://resend.com/api-keys
# Free tier: Use onboarding@resend.dev as FROM_EMAIL
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Floor Interior Service
